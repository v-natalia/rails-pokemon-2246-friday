<div class="container">
  <h1>POKEDEX</h1>


  <div class="cards">
    <% @pokemons.each do |pokemon| %>
    <div class="card-category" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= cl_image_path pokemon.photo.key %>')">
      <h2><%= link_to pokemon.name, pokemon_path(pokemon) %></h2>

      <p><%= pokemon.element_type %></p>
    </div>
    <% end %>
  </div>



</div>
